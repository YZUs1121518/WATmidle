$log = "$env:USERPROFILE\Desktop\disk_active.txt"
"File-based execution started at $(Get-Date)" | Out-File -FilePath $log -Force

for ($i=1; $i -le 10; $i++) {
    "Disk-log $i at $(Get-Date)" | Out-File -FilePath $log -Append
    Start-Sleep -Seconds 5
}

Remove-Item $MyInvocation.MyCommand.Definition
